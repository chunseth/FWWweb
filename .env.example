# Copy this file to .env and fill in your project values.
#
# Supabase is optional for local play. When configured, the app uses it for
# username availability checks against public.profiles. Use the public anon key
# only; never put a service role key in browser-exposed VITE_* variables.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
